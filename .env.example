# Copy this file to `.env` and fill in your values.
# Never commit the real `.env` — it is git-ignored.

# API key for an OpenAI-compatible provider (OpenRouter, NVIDIA NIM, OpenAI, ...)
OPENROUTER_API_KEY=your_api_key_here

# Base endpoint for the chat completions API
BASE_URL=https://openrouter.ai/api/v1

# Model name
MODEL=meta/llama-3.3-70b-instruct

# Force mock mode even when a key is present: 1 / true / yes / on
LLM_USE_MOCK=0

# Maximum ReAct loop iterations before giving up
REACT_MAX_ITERATIONS=6

# Tool execution timeout in seconds
TOOL_TIMEOUT_SECONDS=10
